{
  "name": "promenade",
  "version": "0.1.0",
  "private": true,
  "description": "A static site generator for walkable Gaussian-splat museums. Generate a 3D room per section, link rooms with doorways, publish a static walkable site.",
  "bin": {
    "promenade": "bin/promenade.mjs"
  },
  "scripts": {
    "promenade": "node bin/promenade.mjs",
    "setup": "node bin/promenade.mjs setup",
    "new": "node bin/promenade.mjs new",
    "dev": "node bin/promenade.mjs dev",
    "edit": "node bin/promenade.mjs edit",
    "check": "node bin/promenade.mjs check",
    "build": "node bin/promenade.mjs build",
    "serve": "node bin/promenade.mjs serve",
    "preview": "node bin/promenade.mjs preview",
    "clean": "node bin/promenade.mjs clean",
    "lint": "npm --prefix engine run lint"
  },
  "license": "MIT"
}
